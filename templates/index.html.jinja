<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ profile.name }}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 15px;
  line-height: 1.7;
  color: #1a1a1a;
  background: #fff;
}

a { color: #2563eb; text-decoration: none; }
a:hover { text-decoration: underline; }

.wrap {
  max-width: 740px;
  margin: 0 auto;
  padding: 0 1.5rem;
}

/* ── NAV ── */
nav {
  position: sticky; top: 0;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(8px);
  border-bottom: 1px solid #e5e7eb;
  padding: 0.8rem 0;
  z-index: 10;
}
.nav-row { display: flex; justify-content: space-between; align-items: center; }
.nav-name { font-weight: 600; font-size: 0.9rem; color: #111; text-decoration: none; }
.nav-name:hover { text-decoration: none; }
.nav-links { display: flex; gap: 1.5rem; list-style: none; }
.nav-links a { font-size: 0.85rem; color: #555; }
.nav-links a:hover { color: #111; text-decoration: none; }

/* ── PROFILE ── */
.profile {
  display: flex;
  gap: 2.5rem;
  align-items: flex-start;
  padding: 3rem 0 2.5rem;
  border-bottom: 1px solid #e5e7eb;
}
.profile img {
  width: 155px;
  height: auto;
  border-radius: 4px;
  flex-shrink: 0;
  display: block;
}
.profile-text h1 {
  font-size: 1.6rem;
  font-weight: 600;
  letter-spacing: -0.015em;
  line-height: 1.2;
  margin-bottom: 0.5rem;
}
.profile-affil {
  font-size: 0.875rem;
  color: #555;
  line-height: 1.65;
  margin-bottom: 0.8rem;
}
.profile-affil a { color: inherit; text-decoration-color: #ccc; text-decoration: underline; }
.profile-affil a:hover { color: #111; text-decoration-color: #111; }
.profile-links {
  display: flex;
  flex-wrap: wrap;
  gap: 0.45rem;
}
.profile-links a {
  font-size: 0.78rem;
  color: #374151;
  border: 1px solid #d1d5db;
  padding: 0.18rem 0.65rem;
  border-radius: 3px;
  text-decoration: none;
  transition: border-color 0.15s;
}
.profile-links a:hover { border-color: #9ca3af; text-decoration: none; }

/* ── BIO ── */
.bio { padding: 2.25rem 0 2rem; border-bottom: 1px solid #e5e7eb; }
.bio p { font-size: 0.9rem; color: #374151; margin-bottom: 0.75rem; }
.bio p:last-of-type { margin-bottom: 0; }
.interests {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  margin-top: 1rem;
}
.interest {
  font-size: 0.75rem;
  color: #555;
  background: #f3f4f6;
  padding: 0.15rem 0.65rem;
  border-radius: 999px;
}

/* ── SECTION ── */
.section { padding: 2rem 0; border-bottom: 1px solid #e5e7eb; }
.section:last-of-type { border-bottom: none; }
.sec-title {
  font-size: 0.7rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: #6b7280;
  margin-bottom: 1.25rem;
}

/* ── PUBLICATIONS ── */
.pub-list { display: flex; flex-direction: column; gap: 1.2rem; }
.pub { display: grid; grid-template-columns: 1.5rem 1fr; gap: 0 0.75rem; }
.pub-num { color: #9ca3af; font-size: 0.8rem; padding-top: 0.15rem; }
.pub-title { font-weight: 500; font-size: 0.9rem; color: #111; margin-bottom: 0.15rem; line-height: 1.45; }
.pub-title a { color: inherit; }
.pub-title a:hover { text-decoration: underline; }
.pub-badge {
  display: inline-block;
  font-size: 0.63rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  background: #ede9fe;
  color: #5b21b6;
  padding: 0.07rem 0.4rem;
  border-radius: 2px;
  margin-left: 0.35rem;
  vertical-align: middle;
}
.pub-badge.inprep { background: #f3f4f6; color: #9ca3af; }
.pub-meta { font-size: 0.82rem; color: #6b7280; line-height: 1.5; }
.pub-meta .me { color: #374151; font-weight: 500; }

/* ── SERVICE ── */
.service-list { font-size: 0.875rem; color: #374151; line-height: 1.95; }

/* ── FOOTER ── */
footer { padding: 2rem 0 3rem; text-align: center; font-size: 0.775rem; color: #9ca3af; }

/* ── RESPONSIVE ── */
@media (max-width: 600px) {
  .profile { flex-direction: column; gap: 1.5rem; padding: 2rem 0 2rem; }
  .profile img { width: 120px; height: 150px; }
  .profile-text h1 { font-size: 1.35rem; }
}
</style>
</head>
<body>

<nav>
  <div class="wrap">
    <div class="nav-row">
      <a href="#" class="nav-name">{{ profile.name }}</a>
      <ul class="nav-links">
        <li><a href="#about">About</a></li>
        <li><a href="#publications">Publications</a></li>
        <li><a href="cv.html">CV</a></li>
      </ul>
    </div>
  </div>
</nav>

<main class="wrap">

  <div class="profile" id="about">
    {% if portrait_gif_exists %}
    <img src="assets/img/portrait.gif" alt="{{ profile.name }}">
    {% elif profile.photo %}
    <img src="{{ profile.photo }}" alt="{{ profile.name }}">
    {% endif %}
    <div class="profile-text">
      <h1>{{ profile.name }}</h1>
      <div class="profile-affil">
        {{ profile.status }} · {{ profile.department }}<br>
        {{ profile.institution }}{% if profile.location %}, {{ profile.location }}{% endif %}
        {% if profile.advisor %}<br>Advised by <a href="{{ profile.advisor.url }}">{{ profile.advisor.name }}</a>{% endif %}
      </div>
      <div class="profile-links">
        {% if profile.contact.email %}<a href="mailto:{{ profile.contact.email }}">Email</a>{% endif %}
        {% if profile.contact.scholar %}<a href="{{ profile.contact.scholar }}" target="_blank">Google Scholar</a>{% endif %}
        {% if profile.contact.github %}<a href="https://github.com/{{ profile.contact.github }}" target="_blank">GitHub</a>{% endif %}
        {% if profile.contact.linkedin %}<a href="https://linkedin.com/in/{{ profile.contact.linkedin }}" target="_blank">LinkedIn</a>{% endif %}
        {% if profile.contact.twitter %}<a href="https://twitter.com/{{ profile.contact.twitter }}" target="_blank">Twitter</a>{% endif %}
        {% if cv_pdf_exists %}<a href="assets/pdf/cv.pdf" target="_blank">CV</a>{% endif %}
      </div>
    </div>
  </div>

  <div class="bio">
    {% for para in profile.bio %}
    <p>{{ para }}</p>
    {% endfor %}
    {% if profile.interests %}
    <div class="interests">
      {% for interest in profile.interests %}
      <span class="interest">{{ interest }}</span>
      {% endfor %}
    </div>
    {% endif %}
  </div>

  <div class="section" id="publications">
    <div class="sec-title">Publications</div>
    <div class="pub-list">
      {% for pub in publications %}
      <div class="pub">
        <div class="pub-num">{{ loop.index }}</div>
        <div>
          <div class="pub-title">
            {% if pub.url %}<a href="{{ pub.url }}" target="_blank">{{ pub.title }}</a>
            {% else %}{{ pub.title }}{% endif %}
            <span class="pub-badge {{ 'inprep' if pub.status == 'inprep' else '' }}">{{ pub.badge }}</span>
          </div>
          <div class="pub-meta">
            {% for author in pub.authors %}
              <span class="{{ 'me' if author == profile.name else '' }}">{{ author }}</span>{% if not loop.last %}, {% endif %}
            {% endfor %}
            · {{ pub.venue }}
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>

  <div class="section">
    <div class="sec-title">Academic Service</div>
    <div class="service-list">
      {% for s in profile.service %}{{ s }}<br>{% endfor %}
    </div>
  </div>

</main>

<footer>
  <div class="wrap">© {{ build_year }} {{ profile.name }}</div>
</footer>

</body>
</html>
